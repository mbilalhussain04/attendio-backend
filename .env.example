COMPOSE_PROJECT_NAME=attendio-platform
GATEWAY_BIND=0.0.0.0
GATEWAY_PORT=80
INFRA_BIND=127.0.0.1

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
AUTH_DB_NAME=attendio_auth
ATTENDANCE_DB_NAME=attendio_attendance
STORAGE_DB_NAME=attendio_storage
NOTIFICATION_DB_NAME=attendio_notification
LEAVE_DB_NAME=attendio_leave
BILLING_DB_NAME=attendio_billing

AUTH_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/attendio_auth
ATTENDANCE_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/attendio_attendance
STORAGE_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/attendio_storage
NOTIFICATION_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/attendio_notification
LEAVE_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/attendio_leave
BILLING_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/attendio_billing

REDIS_URL=redis://localhost:6379/0
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
BROKER_BACKEND=redis

SECRET_KEY=change-this-in-production
JWT_ACCESS_SECRET=change-this-in-production
COOKIE_SECURE=false
COOKIE_DOMAIN=
SESSION_COOKIE_NAME=attendio_session
REFRESH_COOKIE_NAME=attendio_refresh
ACCESS_TOKEN_COOKIE_NAME=access_token

DEFAULT_ROOT_DOMAIN=lvh.me
AUTH_BASE_DOMAIN=auth.lvh.me
BASE_DOMAIN=lvh.me
FRONTEND_BASE_URL=http://localhost:5173
FRONTEND_AFTER_LOGIN=/dashboard
ALLOW_EMAIL_LOGIN_FALLBACK=true
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15

AUTH_SERVICE_URL=http://localhost:8000
ATTENDANCE_SERVICE_URL=http://localhost:8001
STORAGE_SERVICE_URL=http://localhost:8002
NOTIFICATION_SERVICE_URL=http://localhost:8003
LEAVE_SERVICE_URL=http://localhost:8004
BILLING_SERVICE_URL=http://localhost:8005
DOCS_GATEWAY_URL=http://localhost:8090
GATEWAY_PUBLIC_URL=http://localhost:8090
PUBLIC_AUTH_API_URL=http://localhost:8090
PUBLIC_ATTENDANCE_API_URL=http://localhost:8090
PUBLIC_STORAGE_API_URL=http://localhost:8090
PUBLIC_NOTIFICATION_API_URL=http://localhost:8090
PUBLIC_LEAVE_API_URL=http://localhost:8090
PUBLIC_BILLING_API_URL=http://localhost:8090

API_V1_PREFIX=/api/v1
APP_ENV=development
APP_HOST=0.0.0.0
AUTH_APP_PORT=8000
ATTENDANCE_APP_PORT=8001
STORAGE_APP_PORT=8002
NOTIFICATION_APP_PORT=8003
LEAVE_APP_PORT=8004
BILLING_APP_PORT=8005
INTERNAL_SERVICE_TOKEN=change-me-internal
DEBUG=true
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173,http://localhost:8000,http://localhost:8001,http://localhost:8090
DEFAULT_TIMEZONE=Europe/Berlin
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET=attendio-files
STORAGE_BACKEND=auto
LOCAL_STORAGE_DIR=./.local-storage
PUBLIC_STORAGE_BASE_URL=http://localhost:8090/api/v1/storage/files
MAX_UPLOAD_BYTES=5242880

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:8090/api/v1/auth/sso/callback
SSO_AUTO_PROVISION=false
SSO_DEFAULT_ROLE=employee

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@attendio.local
SMTP_USE_TLS=true

BILLING_ENABLED=false
BILLING_PROVIDER=stripe
TRIAL_DAYS=60
BILLING_CURRENCY=eur
STANDARD_PLAN_PRICE_CENTS=3000
STANDARD_PLAN_INCLUDED_LICENSES=25
PAYMENT_GRACE_DAYS=7
BILLING_SUCCESS_URL=http://localhost:5173/settings?tab=billing&billing=success
BILLING_CANCEL_URL=http://localhost:5173/settings?tab=billing&billing=cancelled
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STANDARD=
PAYONEER_CLIENT_ID=
PAYONEER_CLIENT_SECRET=
PAYONEER_WEBHOOK_SECRET=

# Production deploy values kept in the same .env file.
# Local services ignore PROD_* keys. `make sync-env` uses them to render the
# GitHub/VPS production env without needing a second env file.
PROD_ROOT_DOMAIN=attendio.technoflick.com
PROD_API_DOMAIN=api.attendio.technoflick.com
PROD_FRONTEND_BASE_URL=https://attendio.technoflick.com
PROD_API_BASE_URL=https://api.attendio.technoflick.com
PROD_POSTGRES_USER=attendio
PROD_POSTGRES_PASSWORD=
PROD_RABBITMQ_DEFAULT_USER=attendio
PROD_RABBITMQ_DEFAULT_PASS=
PROD_MINIO_ACCESS_KEY=
PROD_MINIO_SECRET_KEY=
PROD_SECRET_KEY=
PROD_JWT_ACCESS_SECRET=
PROD_INTERNAL_SERVICE_TOKEN=
