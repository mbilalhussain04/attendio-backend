COMPOSE_PROJECT_NAME=attendio-platform
GATEWAY_BIND=127.0.0.1
GATEWAY_PORT=8080
INFRA_BIND=127.0.0.1

POSTGRES_USER=attendio
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_HOST=platform-postgres
POSTGRES_PORT=5432
AUTH_DB_NAME=attendio_auth
ATTENDANCE_DB_NAME=attendio_attendance
STORAGE_DB_NAME=attendio_storage
NOTIFICATION_DB_NAME=attendio_notification
LEAVE_DB_NAME=attendio_leave
BILLING_DB_NAME=attendio_billing

AUTH_DATABASE_URL=postgresql+psycopg://attendio:replace-with-a-long-random-password@platform-postgres:5432/attendio_auth
ATTENDANCE_DATABASE_URL=postgresql+psycopg://attendio:replace-with-a-long-random-password@platform-postgres:5432/attendio_attendance
STORAGE_DATABASE_URL=postgresql+psycopg://attendio:replace-with-a-long-random-password@platform-postgres:5432/attendio_storage
NOTIFICATION_DATABASE_URL=postgresql+psycopg://attendio:replace-with-a-long-random-password@platform-postgres:5432/attendio_notification
LEAVE_DATABASE_URL=postgresql+psycopg://attendio:replace-with-a-long-random-password@platform-postgres:5432/attendio_leave
BILLING_DATABASE_URL=postgresql+psycopg://attendio:replace-with-a-long-random-password@platform-postgres:5432/attendio_billing

REDIS_URL=redis://redis:6379/0
RABBITMQ_DEFAULT_USER=attendio
RABBITMQ_DEFAULT_PASS=replace-rabbitmq-password
RABBITMQ_URL=amqp://attendio:replace-rabbitmq-password@rabbitmq:5672/
BROKER_BACKEND=redis

APP_ENV=production
DEBUG=false
APP_HOST=0.0.0.0
AUTH_APP_PORT=8000
ATTENDANCE_APP_PORT=8001
STORAGE_APP_PORT=8002
NOTIFICATION_APP_PORT=8003
LEAVE_APP_PORT=8004
BILLING_APP_PORT=8005
DOCS_GATEWAY_PORT=8090

SECRET_KEY=replace-with-64-random-characters
JWT_ACCESS_SECRET=replace-with-another-64-random-characters
INTERNAL_SERVICE_TOKEN=replace-with-another-long-random-token

COOKIE_SECURE=true
COOKIE_DOMAIN=.attendio.technoflick.com
SESSION_COOKIE_NAME=attendio_session
REFRESH_COOKIE_NAME=attendio_refresh
ACCESS_TOKEN_COOKIE_NAME=access_token

DEFAULT_ROOT_DOMAIN=attendio.technoflick.com
AUTH_BASE_DOMAIN=api.attendio.technoflick.com
BASE_DOMAIN=attendio.technoflick.com
FRONTEND_BASE_URL=https://attendio.technoflick.com
FRONTEND_AFTER_LOGIN=/dashboard
ALLOW_EMAIL_LOGIN_FALLBACK=true
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15

AUTH_SERVICE_URL=http://auth-service:8000
ATTENDANCE_SERVICE_URL=http://attendance-service:8001
STORAGE_SERVICE_URL=http://storage-service:8002
NOTIFICATION_SERVICE_URL=http://notification-service:8003
LEAVE_SERVICE_URL=http://leave-service:8004
BILLING_SERVICE_URL=http://billing-service:8005
DOCS_GATEWAY_URL=http://docs-gateway:8090

GATEWAY_PUBLIC_URL=https://api.attendio.technoflick.com
PUBLIC_AUTH_API_URL=https://api.attendio.technoflick.com
PUBLIC_ATTENDANCE_API_URL=https://api.attendio.technoflick.com
PUBLIC_STORAGE_API_URL=https://api.attendio.technoflick.com
PUBLIC_NOTIFICATION_API_URL=https://api.attendio.technoflick.com
PUBLIC_LEAVE_API_URL=https://api.attendio.technoflick.com
PUBLIC_BILLING_API_URL=https://api.attendio.technoflick.com
PUBLIC_STORAGE_BASE_URL=https://api.attendio.technoflick.com/api/v1/storage/files

API_V1_PREFIX=/api/v1
CORS_ORIGINS=https://attendio.technoflick.com,https://api.attendio.technoflick.com
DEFAULT_TIMEZONE=Europe/Berlin

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=replace-minio-access-key
MINIO_SECRET_KEY=replace-minio-secret-key
MINIO_SECURE=false
MINIO_BUCKET=attendio-files
STORAGE_BACKEND=minio
LOCAL_STORAGE_DIR=./.local-storage
MAX_UPLOAD_BYTES=5242880

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
OAUTH_REDIRECT_URI=https://api.attendio.technoflick.com/api/v1/auth/sso/callback
SSO_AUTO_PROVISION=false
SSO_DEFAULT_ROLE=employee

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@attendio.technoflick.com
SMTP_USE_TLS=true

BILLING_ENABLED=false
BILLING_PROVIDER=stripe
TRIAL_DAYS=60
BILLING_CURRENCY=eur
STANDARD_PLAN_PRICE_CENTS=3000
STANDARD_PLAN_INCLUDED_LICENSES=25
PAYMENT_GRACE_DAYS=7
BILLING_SUCCESS_URL=https://attendio.technoflick.com/settings?tab=billing&billing=success
BILLING_CANCEL_URL=https://attendio.technoflick.com/settings?tab=billing&billing=cancelled
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STANDARD=
PAYONEER_CLIENT_ID=
PAYONEER_CLIENT_SECRET=
PAYONEER_WEBHOOK_SECRET=
